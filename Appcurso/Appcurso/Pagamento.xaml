        Text="Atenção o cartão deve ser de credito com limite disponível para compra! Não fazemos remboolso de assinaturas*"
            TextColor="Red"
            FontSize="Small"
        />
        <Entry
        x:Name="numerocartao"
        />
        <Label
        Text="Data Validade"
        />
        <Entry
        x:Name="datavalidade"
        />
        <Label
        Text="CVV"
        />
        <Entry
        x:Name="cvv"
        />
