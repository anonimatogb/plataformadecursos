            Text="Valor: R$ 55,00/mês"
            FontSize="40"
             />
        <Label
            Text="Nome no Cartão"
            />
        
        <Entry
             x:Name="nomenocartao"
             />
        <Label
       Text="Numero do Cartão"
       />
